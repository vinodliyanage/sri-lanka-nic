{
  "name": "sri-lanka-nic",
  "version": "1.0.0",
  "private": true,
  "description": "Sri Lanka NIC decoder and validator",
  "scripts": {
    "dev": "pnpm --filter \"./apps/*\" dev",
    "build": "pnpm --filter \"./packages/*\" build && pnpm --filter \"./apps/*\" build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm --filter \"./packages/*\" build && changeset publish",
    "prepare": "lefthook install"
  },
  "keywords": [],
  "author": "Vinod Liyanage",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "prettier": "^3.0.0"
  }
}
